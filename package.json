{
  "name": "mujskaiaopora",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@mujskaiaopora/web",
    "dev:api": "npm run dev --workspace=@mujskaiaopora/api",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.16"
    }
  }
}
